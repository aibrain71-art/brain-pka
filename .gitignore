# ── Backend-only data (never deployed) ────────────────────────────
# SQLite DB used by the agent team backend — contains private journal,
# CRM, notes, documents tables. Stays on the local machine only.
mypka.db
mypka.db-*
mypka.db.README

# Schemas + seed scripts — backend-only artifacts, no need on the PWA host.
mypka.db.schema*.sql
mypka.db.seed*.sql

# Phase 3a books-hybrid: generated data dumps (regenerable from mypka.db
# via `python migrate_books_to_hybrid.py --emit-d1`). Bulky, contain book
# descriptions, no value in version control. schema-books.sql IS committed.
migration-books.sql
migration-notes-books.sql
migration-people-authors.sql

# PKM system docs that aren't part of the deployed app
INDEX.md
SOP/

# Image originals from screenshot ingestion (might be private + bulky)
Images/

# ── Claude Code temp artifacts (path-concat bugs leak these) ──────
# Filename starts with "C" and a non-standard char (NTFS alternate stream
# from a bad path concat); use a broad glob so they never get committed.
*claude-notify-signals*
C*UsersUser*

# ── OS / IDE / sync junk ──────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.lnk
~$*
*.tmp
*.swp
.vscode/
.idea/

# ── Node / build (in case anything appears later) ─────────────────
node_modules/
dist/
build/

# ── Playwright E2E test artifacts ─────────────────────────────────
test-results/
playwright-report/
playwright/.cache/
blob-report/
index.html.bak-phase4
